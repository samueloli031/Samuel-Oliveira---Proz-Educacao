#Função para o histórico de clientes
def historico_cliente():

  while True:
    cpf = input("Digite o CPF do cliente: ")
    cpf_limpo = limpar_cpf(cpf)

    if cpf_limpo not in clientes:
      print("⚠️ Cliente não encontrado.")
      return

    total = 0
    tem_pet = False

    print(f"\n📊 Histórico de {clientes[cpf_limpo]['nome_cliente']}:")

    for pet in pets.values():
      if pet['cpf_tutor'] == cpf_limpo:
        tem_pet = True
        print(f"\n🐶 Pet: {pet['nome_pet']}")

        for servico in pet['servicos']:
          print(f" - {servico['nome_serv']} R$ {servico['preco_serv']:.2f}")
          total += servico['preco_serv']

    if not tem_pet:
      print("⚠️ Cliente não possui pets cadastrados.")

    print(f"\n💰 Total gasto: R$ {total:.2f}")

    print('''
        - O que deseja fazer agora? -
    1 - Voltar ao menu principal
    9 - Voltar ao menu anterior
    ''')

    opcao = ler_opcao("Digite uma opção: ", [1,9])

    if opcao == 1:
      return
    elif opcao == 9:
      print("\n↩️ Voltando ao menu anterior...")
      return

