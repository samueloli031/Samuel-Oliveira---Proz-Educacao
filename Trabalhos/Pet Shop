#Função para cadastrar o cliente
def cadastrar_cliente():

  while True:
    print("\n   - DADOS PESSOAIS -")

    while True:
      nome_cliente = input("Informe seu nome completo: ").strip().title()
      if not nome_cliente:
        print("⚠️ Nome não pode estar vazio.")
        continue
      if not nome_cliente.replace(" ", "").isalpha() or (len(nome_cliente) <= 1):
        print("⚠️ Nome inválido.")
        continue
      break

    while True:
      cpf_cliente = input("CPF: ").strip()
      cpf_limpo = limpar_cpf(cpf_cliente)
      if not cpf_cliente:
        print("⚠️ CPF não pode estar vazio.")
        continue
      if not cpf_limpo.isdigit():
        print("⚠️ CPF não pode conter letras.")
        continue
      if not len(cpf_limpo) == 11:
        print("⚠️ CPF deve conter 11 dígitos.")
        continue
      if cpf_limpo in clientes:
        print(f'⚠️ CPF "{formatar_cpf(cpf_limpo)}" já cadastrado!')
        continue
      break

    while True:
      telefone = input("Telefone: ").strip()
      telefone_limpo = limpar_telefone(telefone)
      if not telefone:
        print("⚠️ Telefone não pode estar vazio.")
        continue
      if not telefone_limpo.isdigit():
        print("⚠️ Telefone não deve conter letras.")
        continue
      if len(telefone_limpo) < 10 or len(telefone_limpo) > 11:
        print("⚠️ Telefone inválido. Digite DDD + número.")
        continue
      if telefone_limpo in telefones:
        print("⚠️ Telefone já cadastrado!")
        continue
      break

    while True:
      email = input("E-mail: ").strip().lower()
      if not email:
        print("⚠️ E-mail não pode estar vazio.")
        continue
      if not (len(email) >= 6 and "@" in email and "." in email.split("@")[-1] and " " not in email):
        print("⚠️ E-mail incorreto.")
        email = email
        continue
      break

    print("\n   - ENDEREÇO -")
    while True:
      estado = input("Estado: ").strip().upper()
      if not estado:
        print("⚠️ Estado não pode estar vazio.")
        continue
      if not estado.replace(" ","").isalpha() or len(estado) <=1:
        print("⚠️ Estado inválido.")
        continue
      break

    while True:
      cidade = input("Cidade: ").strip().title()
      if not cidade:
        print("⚠️ Cidade não pode estar vazia.")
        continue
      if not cidade.replace(" ","").isalpha() or len(cidade) <=1:
        print("⚠️ Cidade inválida.")
        continue
      break

    while True:
      bairro = input("Bairro: ").strip().title()
      if not bairro:
        print("⚠️ Bairro não pode estar vazio.")
        continue
      if not bairro.replace(" ","").isalpha() or len(bairro) <=1:
        print("⚠️ Bairro inválido.")
        continue
      break

    while True:
      rua = input("Rua: ").title()
      if not rua.replace(" ",""):
        print("⚠️ Rua não pode estar vazio.")
        continue
      if not rua.startswith(("R", "R.", "Rua")):
        rua = f"Rua {rua}"
      break

    while True:
      numero = input('Número da residência (Informe "S/N" para sem número): ').strip().lower()
      if not numero:
        print("⚠️ Número não pode estar vazio.")
        continue
      if numero.isdigit():
        numero = int(numero)
        break
      else:
        if numero == "s/n":
          break
        else:
          print("⚠️ Número inválido.")

    while True:
      cep = input("CEP: ").strip()
      cep_limpo = limpar_cep(cep)
      if not cep_limpo:
        print("⚠️ CEP não pode estar vazio.")
        continue
      if len(cep_limpo) != 8:
        print("⚠️ CEP precisa conter 8 dígitos.")
        continue
      if not cep_limpo.isdigit():
        print("⚠️ CEP não pode conter letras.")
        continue
      cep_formatado = formatar_cep(cep_limpo)
      endereco = f"{rua}, {numero}, {bairro}, {cidade}/{estado} - {cep_formatado}"
      break

    clientes[cpf_limpo] = {
    "nome_cliente": nome_cliente,
    "telefone": telefone,
    "email": email,
    "endereco": endereco
    }
    telefones.add(telefone_limpo)

    print("\n✅ Cliente cadastrado com sucesso!")

    print('''
      - O que deseja fazer agora? -
  1 - Cadastrar outro cliente
  2 - Listar clientes cadastrados
  9 - Voltar ao menu anterior
  ''')

    opcao_clientes = ler_opcao("Digite uma opção: ",[1,2,9])

    if opcao_clientes == 1:
      continue
    elif opcao_clientes == 2:
      listar_clientes()
    elif opcao_clientes == 9:
      print("\n↩️ Voltando ao menu anterior...")
      return

