#Função para chamar um título
def titulo(texto):
  print(f'\n{"="*10} {texto} {"="*10}')

#Função para validar a entrada de dados como número inteiro
def ler_opcao(mensagem, opcoes_validas):
  while True:
    opcao = input(mensagem)
    if opcao.isdigit() and int(opcao) in opcoes_validas:
      return int(opcao)

    print("\n⚠️ Opção inválida!")

